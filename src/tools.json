  {
    "name": "rag_chunk_text",
    "description": "Split text into chunks for embedding. 'window' = overlapping token windows; 'recursive' = natural-boundary split. Pure (no DB write); returns chunks so the caller can embed each and pass them to rag_ingest_document.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "Document text to chunk."
        },
        "chunkSize": {
          "type": "integer",
          "description": "Target tokens per chunk (default 200)."
        },
        "overlap": {
          "type": "integer",
          "description": "Tokens shared between adjacent chunks (default 40)."
        },
        "strategy": {
          "type": "string",
          "enum": [
            "window",
            "recursive"
          ],
          "description": "Chunking strategy: 'window' (sliding token window, default) or 'recursive' (split on paragraph -> line -> sentence -> word boundaries)."
        }
      },
      "required": [
        "text"
      ]
    }
  },
  {
    "name": "rag_parent_child_chunk",
    "description": "Parent-child chunking: returns small retrieval 'children' plus the larger 'parent' each was cut from (parentOrdinal back-reference). Embed and retrieve on children, then expand a hit to its parent for generation context. Pure (no DB write).",
    "inputSchema": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "Document text to chunk."
        },
        "parentSize": {
          "type": "integer",
          "description": "Parent (context) token budget (default 400)."
        },
        "childSize": {
          "type": "integer",
          "description": "Child (retrieval) token budget (default 100)."
        },
        "childOverlap": {
          "type": "integer",
          "description": "Token overlap between adjacent children (default 20)."
        }
      },
      "required": [
        "text"
      ]
    }
  },
  {
    "name": "rag_ingest_document",
    "description": "Store a document and its pre-embedded chunks. Each chunk needs a 384-dim embedding (computed by the caller's embedder, e.g. Voyage AI).",
    "inputSchema": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Document id (string key)."
        },
        "uri": {
          "type": "string",
          "description": "Optional source URI."
        },
        "title": {
          "type": "string",
          "description": "Optional title."
        },
        "metadata": {
          "type": "string",
          "description": "Optional metadata as a JSON string (default {})."
        },
        "chunks": {
          "type": "array",
          "description": "Chunk objects.",
          "items": {
            "type": "object",
            "properties": {
              "content": {
                "type": "string"
              },
              "embedding": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "description": "384-dim vector."
              },
              "ordinal": {
                "type": "integer"
              },
              "id": {
                "type": "string"
              },
              "tokenCount": {
                "type": "integer"
              }
            },
            "required": [
              "content",
              "embedding"
            ]
          }
        }
      },
      "required": [
        "id",
        "chunks"
      ]
    }
  },
  {
    "name": "rag_upsert_chunks",
    "description": "Upsert chunks (with 384-dim embeddings) for an existing document without changing the document row.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "documentId": {
          "type": "string"
        },
        "chunks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "content": {
                "type": "string"
              },
              "embedding": {
                "type": "array",
                "items": {
                  "type": "number"
                }
              },
              "ordinal": {
                "type": "integer"
              },
              "id": {
                "type": "string"
              },
              "tokenCount": {
                "type": "integer"
              }
            },
            "required": [
              "content",
              "embedding"
            ]
          }
        }
      },
      "required": [
        "documentId",
        "chunks"
      ]
    }
  },
  {
    "name": "rag_search",
    "description": "Hybrid retrieval over chunks: semantic (vector) + lexical (text) candidates fused with Reciprocal Rank Fusion, optionally diversified with MMR. Provide 'vector' (query embedding) and/or 'query' (text).",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Lexical query text."
        },
        "vector": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Query embedding (384-dim)."
        },
        "k": {
          "type": "integer",
          "description": "Final results (default 10)."
        },
        "vecK": {
          "type": "integer",
          "description": "Vector candidates to fuse (default 30)."
        },
        "textK": {
          "type": "integer",
          "description": "Lexical candidates to fuse (default 30)."
        },
        "metric": {
          "type": "string",
          "enum": [
            "euclidean",
            "cosine"
          ],
          "description": "Vector distance (default euclidean)."
        },
        "mmr": {
          "type": "boolean",
          "description": "Apply MMR diversity re-ranking (default false)."
        },
        "lambda": {
          "type": "number",
          "description": "MMR relevance/diversity tradeoff 0..1 (default 0.5)."
        },
        "rrfK": {
          "type": "number",
          "description": "RRF constant (default 60)."
        }
      }
    }
  },
  {
    "name": "rag_vector_search",
    "description": "Pure semantic search over chunks by embedding distance (no lexical fusion).",
    "inputSchema": {
      "type": "object",
      "properties": {
        "vector": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Query embedding (384-dim)."
        },
        "k": {
          "type": "integer",
          "description": "Max results (default 10)."
        },
        "metric": {
          "type": "string",
          "enum": [
            "euclidean",
            "cosine"
          ]
        }
      },
      "required": [
        "vector"
      ]
    }
  },
